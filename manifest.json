{
  "manifest_version": 3,
  "name": "Zero-Hallucination Research Sidebar",
  "version": "1.0",
  "description": "Zero-hallucination research sidebar backed by a custom MCP server, with Prompt Evaluator functionality.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "action": {
    "default_title": "Open Truth Sidebar"
  },
  "side_panel": {
    "default_path": "ui/sidebar.html"
  }
}
